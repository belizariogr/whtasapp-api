# Server
PORT=6000

# Nome exibido no WhatsApp ao parear o dispositivo (Browsers.baileys)
WHATSAPP_BROWSER_NAME=wpapi

# JWT (validação apenas — tokens são emitidos por outro microserviço)
JWT_SECRET_KEY=

# MariaDB 
DATABASE_HOST=127.0.0.1
DATABASE_PORT=3306
DATABASE_USER=user
DATABASE_PASSWORD=password
DATABASE_NAME=whatsapp_api

# Testes de ação (tenant com conexão WhatsApp ativa)
TEST_TENANT_ID=1
TEST_JWT_TOKEN=
TEST_RECIPIENT_PHONE=5511999999999
